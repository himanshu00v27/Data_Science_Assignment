# Function 1
def f1(a):

    while len(a) < 9:
        a.append(None)

    return [
        a[0:3],
        a[3:6],
        a[6:9]
    ]
# Function 2
def f2(a):

    t = tuple(a)

    return {
        "t": t,
        "mean": mean(a),
        "median": median(a),
        "mode": mode(a)
    }
# Function 3
def f3(a):

    m = f1(a.copy())

    d = f2(a.copy())

    return {
        "m": m,
        "d": d
    }
# Input
a = list(map(int, input("Enter values: ").split()))

# Output
print(f3(a))
